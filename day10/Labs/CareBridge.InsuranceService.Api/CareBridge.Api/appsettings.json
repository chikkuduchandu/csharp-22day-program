{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*",

  "ConnectionStrings": {
    "CareBridgeDb": "Server=localhost;Database=CareBridgeDB;Trusted_Connection=True;TrustServerCertificate=True;"
    // Existing database connection setting (not related to Authentication).
  },

  "InsuranceServiceSettings": {
    "BaseUrl": "https://localhost:7048"
    // Existing Day 9 insurance service endpoint (not related to Authentication).
  },

  "JwtSettings": {
    // [AUTH] Secret key used to digitally sign JWT tokens.
    // The API uses this key to verify that tokens have not been tampered with.
    "Secret": "CareBridge_SuperSecretKey_HCA_2025_Training",

    // [AUTH] Identifies which application issued the token.
    // Helps prevent tokens from untrusted systems being accepted.
    "Issuer": "CareBridge.Api",

    // [AUTH] Identifies who the token is intended for.
    // The API validates this value before allowing access.
    "Audience": "CareBridge.Clients",

    // [AUTH] Token expiration time in minutes.
    // Limits how long a stolen token can be used before requiring login again.
    "ExpiryMinutes": 60
  }
}
